rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/settings/system).data.adminUids ||
        request.auth.uid == get(/databases/$(database)/documents/settings/system).data.adminUid
      );
    }

    function yearFrozen(yearId) {
      return get(/databases/$(database)/documents/academicYears/$(yearId)).data.isFrozen == true;
    }

    match /settings/system {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /academicYears/{yearId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /{subCollection}/{docId} {
        allow read: if true;
        allow write: if isAdmin() && !yearFrozen(yearId);
      }
    }
  }
}
